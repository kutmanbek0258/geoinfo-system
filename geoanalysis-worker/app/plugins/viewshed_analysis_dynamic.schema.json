{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Динамический анализ зон видимости",
  "pluginName": "viewshed_analysis_dynamic",
  "icon": "mdi-eye-outline",
  "type": "object",
  "properties": {
    "inputs": {
      "type": "object",
      "properties": {
        "dem_file": {
          "type": "string",
          "format": "terrain-layer",
          "title": "Источник рельефа (DEM)"
        }
      },
      "required": ["dem_file"]
    },
    "parameters": {
      "type": "object",
      "properties": {
        "observer_point": {
          "type": "object",
          "title": "Точка наблюдателя",
          "format": "map-point",
          "properties": {
            "x": { "type": "number", "title": "Долгота (X)" },
            "y": { "type": "number", "title": "Широта (Y)" }
          },
          "required": ["x", "y"]
        },
        "observer_height": {
          "type": "number",
          "title": "Высота наблюдателя (м)",
          "default": 2.0,
          "minimum": 0.0
        },
        "target_height": {
          "type": "number",
          "title": "Высота цели (м)",
          "default": 0.0,
          "minimum": 0.0
        },
        "max_distance": {
          "type": "number",
          "title": "Максимальная дистанция видимости (м)",
          "default": 10000.0,
          "minimum": 1.0
        }
      },
      "required": ["observer_point"]
    }
  }
}
